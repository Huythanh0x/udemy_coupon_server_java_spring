# Environment Variables Configuration Example
# Copy this file to .env and set your actual values
# Or export these variables in your shell/container environment

# Spring Profile (optional, defaults to profile set in docker-compose.prod.yml)
# Available profiles: prod, local
# Leave unset to use profile specified in docker-compose configuration
# SPRING_PROFILES_ACTIVE=prod

# Database Configuration
# IMPORTANT: For LOCAL development, leave SPRING_DATASOURCE_PASSWORD unset or set to 'password'
# This ensures consistency between docker-compose.local.yml and application-local.properties
# For PRODUCTION: Set a secure password here
SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=password  # Uncomment and set to 'password' for local, or leave unset

# Spring Security Basic Auth (for API service only)
SPRING_SECURITY_USER_NAME=user
SPRING_SECURITY_USER_PASSWORD=your_secure_password_here

# JWT Configuration
# IMPORTANT: JWT secret must be at least 32 characters (256 bits) long for security
# Generate a secure random string for production:
#   openssl rand -base64 32
#   or
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CUSTOM_JWT_SECRET=your_super_secret_jwt_key_must_be_at_least_32_characters_long_for_security

# JWT Expiration (optional, defaults to 86400000 ms = 24 hours)
CUSTOM_JWT_EXPIRATION=86400000

# Redis Configuration
SPRING_DATA_REDIS_PASSWORD=

# Observability (Basic Auth for /actuator/prometheus)
# These credentials are used by Spring Boot Actuator endpoints
PROM_ACTUATOR_USER=prometheus
PROM_ACTUATOR_PASSWORD=prometheus

# OpenTelemetry Tracing Endpoint (optional)
# Only override if you need a different Tempo endpoint
# OTLP_ENDPOINT=http://tempo:4318/v1/traces

# Grafana Admin Credentials (Production)
GRAFANA_ADMIN_USER_PROD=admin
GRAFANA_ADMIN_PASSWORD_PROD=admin
