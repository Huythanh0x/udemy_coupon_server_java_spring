<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Keep Spring Boot defaults for normal app logging -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Console Appender (ensures root logger always has an appender) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-},%X{spanId:-}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Dedicated log for auditing every processed coupon URL -->
    <appender name="CRAWLER_URL_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/crawler-urls.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/crawler-urls.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <!-- One line per URL (message contains all fields) -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="crawler.urls" level="INFO" additivity="false">
        <appender-ref ref="CRAWLER_URL_FILE"/>
    </logger>

    <!-- Root logger so general application logs don't disappear -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>

